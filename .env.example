AI_MODE=demo
COPILOT_BACKEND=mock
COPILOT_POSTURE=conservative
BEACON_LLM=mock

# Runtime store. Defaults to memory for local dev. Vercel uses Upstash/Vercel KV
# automatically when these REST credentials are configured.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# SiliconFlow OpenAI-compatible chat completions.
# Set BEACON_LLM=siliconflow to activate for skill-direct modules.
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=MiniMaxAI/MiniMax-M2.5

AGENT_STUDIO_BASE_URL=
AGENT_STUDIO_API_KEY=
AGENT_STUDIO_RUN_URL_TEMPLATE=
AGENT_STUDIO_AGENT_TALKING_POINTS=
AGENT_STUDIO_AGENT_TERM_EXPLAINER=
AGENT_STUDIO_AGENT_NEXT_BEST_ACTION=
AGENT_STUDIO_AGENT_DRAFT_ASSIST=
AGENT_STUDIO_WF_TALKING_POINTS=
AGENT_STUDIO_WF_TERM_EXPLAINER=
AGENT_STUDIO_WF_NEXT_BEST_ACTION=
AGENT_STUDIO_WF_DRAFT_ASSIST=

OPEN_AGENT_BASE_URL=
OPEN_AGENT_API_KEY=
